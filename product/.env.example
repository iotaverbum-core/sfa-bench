# GroundLedger HTTP API configuration.
#
# These are read directly from the process environment by
# product/groundledger/api.py. There is NO automatic .env loader (no third-party
# dependency): export these yourself, or pass them with `docker run -e VAR=...`.
# This file is a reference, not something the app auto-loads.
#
# The core checks (verify, replay, export) need NONE of these - they take their
# inputs as function/CLI arguments. These only configure the optional API server.

# Bind address. Use 0.0.0.0 inside a container; 127.0.0.1 for local only.
GROUNDLEDGER_HOST=127.0.0.1
GROUNDLEDGER_PORT=8000

# Where sealed ledgers / receipts / submissions are written (one dir per tenant).
GROUNDLEDGER_DATA=product/data

# API key -> tenant map. Format: "key1:tenant1,key2:tenant2".
# Generate strong random keys and treat them like passwords. Anyone with a key
# can submit answers and read that tenant's audit data.
GROUNDLEDGER_API_KEYS=demo-key:demo-tenant

# Optional HMAC signing keys for audit exports. Format: "tenant1:secret1,...".
# This is KEYED INTEGRITY (shared-secret HMAC), NOT public-key non-repudiation.
# Keep these secret; share with an auditor only when they need to verify a signed
# export. Leave blank to produce unsigned (but still self-verifying) bundles.
GROUNDLEDGER_SIGNING_KEYS=
